# ============================================================
# Sala karaoke en vivo
# ============================================================

SALA_PID="$BASE_DIR/playback/sala.pid"
SALA_STOP="$BASE_DIR/playback/sala.stop"
SALA_ACTUAL="$BASE_DIR/playback/reproduccion_actual.csv"

formatear_segundos_sala() {
    local total="$1"

    [[ -z "$total" || "$total" -lt 0 ]] && total=0

    printf "%02d:%02d" "$((total / 60))" "$((total % 60))"
}

sala_esta_activa() {
    if [[ -f "$SALA_PID" ]] && kill -0 "$(cat "$SALA_PID")" 2>/dev/null; then
        return 0
    fi

    return 1
}

iniciar_sala() {
    if sala_esta_activa; then
        echo "La sala ya está activa."
        return
    fi

    rm -f "$SALA_STOP"

    nohup /srv/karaoke/bin/reproductor_sala.sh >/dev/null 2>&1 &

    echo "Sala automática iniciada."
    echo "Los usuarios ya pueden entrar a la sala en vivo."

    registrar_evento "ADMIN" "inició sala automática" "-"
}

detener_sala() {
    if ! sala_esta_activa; then
        echo "La sala no está activa."
        return
    fi

    touch "$SALA_STOP"
    sleep 1

    if sala_esta_activa; then
        kill "$(cat "$SALA_PID")" 2>/dev/null || true
    fi

    rm -f "$SALA_PID" "$SALA_STOP"

    echo "id_cola,usuario,id_cancion,titulo,artista,inicio,duracion_seg,estado" > "$SALA_ACTUAL"

    echo "Sala automática detenida."
    registrar_evento "ADMIN" "detuvo sala automática" "-"
}

mostrar_sala_en_vivo() {
    local linea id_cola usuario id_cancion titulo artista inicio duracion_seg estado
    local inicio_epoch ahora_epoch transcurrido restante porcentaje letra_archivo ruta_letra

    clear

    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo -e "${ui_azul}SALA KARAOKE EN VIVO${ui_reset}"
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo

    if ! sala_esta_activa; then
        echo "La sala automática no está activa."
        echo
        echo "Espera a que el administrador la inicie."
        return
    fi

    if [[ ! -f "$SALA_ACTUAL" || $(wc -l < "$SALA_ACTUAL") -le 1 ]]; then
        echo "No hay canción reproduciéndose en este momento."
        echo
        echo "La sala está esperando canciones pendientes en la cola."
        return
    fi

    linea=$(tail -n +2 "$SALA_ACTUAL" | head -n 1)

    id_cola=$(echo "$linea" | awk -F, '{print $1}')
    usuario=$(echo "$linea" | awk -F, '{print $2}')
    id_cancion=$(echo "$linea" | awk -F, '{print $3}')
    titulo=$(echo "$linea" | awk -F, '{print $4}')
    artista=$(echo "$linea" | awk -F, '{print $5}')
    inicio=$(echo "$linea" | awk -F, '{print $6}')
    duracion_seg=$(echo "$linea" | awk -F, '{print $7}')
    estado=$(echo "$linea" | awk -F, '{print $8}')

    inicio_epoch=$(date -d "$inicio" +%s 2>/dev/null)
    ahora_epoch=$(date +%s)

    if [[ -z "$inicio_epoch" ]]; then
        transcurrido=0
    else
        transcurrido=$((ahora_epoch - inicio_epoch))
    fi

    restante=$((duracion_seg - transcurrido))

    (( transcurrido < 0 )) && transcurrido=0
    (( restante < 0 )) && restante=0

    if (( duracion_seg > 0 )); then
        porcentaje=$((transcurrido * 100 / duracion_seg))
    else
        porcentaje=0
    fi

    (( porcentaje > 100 )) && porcentaje=100

    letra_archivo=$(awk -F, -v id="$id_cancion" '$1 == id {print $8; exit}' "$CATALOGO")
    ruta_letra="$BASE_DIR/$letra_archivo"

    echo "Canción actual:   $titulo - $artista"
    echo "Solicitada por:   $usuario"
    echo "Estado:           $estado"
    echo "Tiempo:           $(formatear_segundos_sala "$transcurrido") / $(formatear_segundos_sala "$duracion_seg")"
    echo "Restante:         $(formatear_segundos_sala "$restante")"
    echo "Avance:           $porcentaje%"
    echo

    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo -e "${ui_azul}LETRA${ui_reset}"
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"

    if [[ -f "$ruta_letra" ]]; then
        cat "$ruta_letra"
    else
        echo "No hay letra registrada para esta canción."
    fi

    echo
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo "Actualización automática cada segundo. Presiona S para salir."
}

unirse_sala() {
    local tecla

    registrar_evento "INFO" "se unió a sala en vivo" "-"

    while true; do
        mostrar_sala_en_vivo

        read -rsn1 -t 1 tecla

        if [[ "$tecla" == "s" || "$tecla" == "S" || "$tecla" == "q" || "$tecla" == "Q" ]]; then
            clear
            registrar_evento "INFO" "salió de sala en vivo" "-"
            break
        fi
    done
}

# ============================================================
# Sala en vivo sin parpadeo fuerte
