        return 1
    fi

    linea=$(tail -n +2 "$SALA_ACTUAL" | head -n 1)

    if [[ -z "$linea" ]]; then
        return 1
    fi

    IFS=, read -r SALA_ID_COLA SALA_USUARIO SALA_ID_CANCION SALA_TITULO SALA_ARTISTA SALA_INICIO SALA_DURACION_SEG SALA_ESTADO <<< "$linea"

    return 0
}

sala_calcular_tiempos() {
    local inicio_epoch ahora_epoch

    inicio_epoch=$(date -d "$SALA_INICIO" +%s 2>/dev/null)
    ahora_epoch=$(date +%s)

    if [[ -z "$inicio_epoch" ]]; then
        SALA_TRANSCURRIDO=0
    else
        SALA_TRANSCURRIDO=$((ahora_epoch - inicio_epoch))
    fi

    SALA_RESTANTE=$((SALA_DURACION_SEG - SALA_TRANSCURRIDO))

    (( SALA_TRANSCURRIDO < 0 )) && SALA_TRANSCURRIDO=0
    (( SALA_RESTANTE < 0 )) && SALA_RESTANTE=0

    if (( SALA_DURACION_SEG > 0 )); then
        SALA_PORCENTAJE=$((SALA_TRANSCURRIDO * 100 / SALA_DURACION_SEG))
    else
        SALA_PORCENTAJE=0
    fi

    (( SALA_PORCENTAJE > 100 )) && SALA_PORCENTAJE=100
}

sala_formato_tiempo() {
    local total="$1"

    [[ -z "$total" || "$total" -lt 0 ]] && total=0

    printf "%02d:%02d" "$((total / 60))" "$((total % 60))"
}

sala_dibujar_espera() {
    printf '\033[2J\033[H'

    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo -e "${ui_azul}SALA KARAOKE EN VIVO${ui_reset}"
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo

    if ! sala_esta_activa; then
        echo "La sala automática no está activa."
        echo
        echo "Espera a que el administrador la inicie."
    else
        echo "No hay canción reproduciéndose en este momento."
        echo
        echo "La sala está esperando canciones pendientes en la cola."
    fi

    echo
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo "Presiona S para salir de la sala."
}

sala_dibujar_cancion() {
    local letra_archivo ruta_letra alto max_lineas total_lineas

    letra_archivo=$(awk -F, -v id="$SALA_ID_CANCION" '$1 == id {print $8; exit}' "$CATALOGO")
    ruta_letra="$BASE_DIR/$letra_archivo"

    printf '\033[2J\033[H'

    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo -e "${ui_azul}SALA KARAOKE EN VIVO${ui_reset}"
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo
    echo "Canción actual:   $SALA_TITULO - $SALA_ARTISTA"
    echo "Solicitada por:   $SALA_USUARIO"
    echo "Estado:           $SALA_ESTADO"
    echo "Tiempo:           --:-- / --:--"
    echo "Restante:         --:--"
    echo "Avance:           --%"
    echo
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo -e "${ui_azul}LETRA${ui_reset}"
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"

    alto=$(tput lines 2>/dev/null)
    [[ -z "$alto" ]] && alto=30

    max_lineas=$((alto - 18))
    (( max_lineas < 6 )) && max_lineas=6

    if [[ -f "$ruta_letra" ]]; then
        total_lineas=$(wc -l < "$ruta_letra")

        head -n "$max_lineas" "$ruta_letra"

        if (( total_lineas > max_lineas )); then
            echo
            echo "... letra recortada en pantalla para mantener la sala estable ..."
        fi
    else
        echo "No hay letra registrada para esta canción."
    fi

    echo
    echo -e "${ui_gris}────────────────────────────────────────────────────────────${ui_reset}"
    echo "Actualización automática. Presiona S para salir."
}

sala_actualizar_lineas_tiempo() {
    sala_calcular_tiempos

    tput cup 7 0 2>/dev/null
    tput el 2>/dev/null
    printf "Tiempo:           %s / %s" "$(sala_formato_tiempo "$SALA_TRANSCURRIDO")" "$(sala_formato_tiempo "$SALA_DURACION_SEG")"

    tput cup 8 0 2>/dev/null
    tput el 2>/dev/null
    printf "Restante:         %s" "$(sala_formato_tiempo "$SALA_RESTANTE")"

    tput cup 9 0 2>/dev/null
    tput el 2>/dev/null
    printf "Avance:           %s%%" "$SALA_PORCENTAJE"

    tput cup 0 0 2>/dev/null
}

unirse_sala() {
    local tecla ultimo_id estado_pantalla

    registrar_evento "INFO" "se unió a sala en vivo" "-"

    tput civis 2>/dev/null

    ultimo_id=""
    estado_pantalla=""

    while true; do
        if ! sala_esta_activa; then
            if [[ "$estado_pantalla" != "inactiva" ]]; then
                sala_dibujar_espera
                estado_pantalla="inactiva"
                ultimo_id=""
            fi
        elif ! sala_obtener_actual; then
            if [[ "$estado_pantalla" != "esperando" ]]; then
                sala_dibujar_espera
                estado_pantalla="esperando"
                ultimo_id=""
            fi
        else
            if [[ "$estado_pantalla" != "cancion" || "$ultimo_id" != "$SALA_ID_COLA" ]]; then
                sala_dibujar_cancion
                estado_pantalla="cancion"
                ultimo_id="$SALA_ID_COLA"
            fi

            sala_actualizar_lineas_tiempo
        fi

        tecla=""
        read -rsn1 -t 1 tecla

        if [[ "$tecla" == "s" || "$tecla" == "S" || "$tecla" == "q" || "$tecla" == "Q" ]]; then
            break
        fi
    done

    tput cnorm 2>/dev/null
    clear

    registrar_evento "INFO" "salió de sala en vivo" "-"
}

